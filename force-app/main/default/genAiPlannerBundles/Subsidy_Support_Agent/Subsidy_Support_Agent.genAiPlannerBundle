        <localActions>
            <fullName>CC_Payment_Router_179fj000001gPPd</fullName>
            <description>REQUIRED: Use this action immediately whenever a user mentions a Provider ID (like P-100) or asks to &apos;check a payment.&apos; Do not ask clarifying questions about the program; just trigger this action to fetch the data.</description>
            <developerName>CC_Payment_Router_179fj000001gPPd</developerName>
            <invocationTarget>CC_SubsidyPaymentRouter</invocationTarget>
            <invocationTargetType>apex</invocationTargetType>
            <isConfirmationRequired>false</isConfirmationRequired>
            <isIncludeInProgressIndicator>false</isIncludeInProgressIndicator>
            <localDeveloperName>CC_Payment_Router</localDeveloperName>
            <masterLabel>CC Payment Router</masterLabel>
        </localActions>
